    "node": ">=18.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test:db": "node -e \"require('dotenv').config(); const {Pool}=require('pg'); new Pool({connectionString:process.env.DATABASE_URL,ssl:{rejectUnauthorized:false}}).query('SELECT NOW()').then(r=>console.log('DB OK:',r.rows[0])).catch(e=>console.error('DB ERROR:',e.message))\"",
    "test:crypt": "node hesabeCrypt.js"
  },
